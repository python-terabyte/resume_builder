# NextAuth
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Admin SDK (from Firebase Console > Project settings > Service accounts > Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Web API Key (same value as the old NEXT_PUBLIC_FIREBASE_API_KEY — used server-side only for email/password auth)
FIREBASE_WEB_API_KEY=
